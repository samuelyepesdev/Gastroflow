{
  "name": "gastroflow",
  "version": "1.3.15",
  "description": "Sistema de Facturación para GastroFlow",
  "main": "electron/main.js",
  "bin": "server.js",
  "pkg": {
    "assets": [
      "views/**/*",
      "public/**/*",
      "node_modules/ejs/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "scripts": {
    "start": "node scripts/run-migrations.js && node scripts/create-admin.js && node scripts/seed-doc-types.js && node scripts/seed-temas-parametros.js && node server.js",
    "dev": "nodemon server.js",
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production' && process.env.HUSKY !== '0') { require('child_process').execSync('husky', {stdio: 'inherit'}) }\"",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "package": "pkg . --public --target node18-win-x64",
    "migrate": "node scripts/run-migrations.js",
    "seed:docs": "node scripts/seed-doc-types.js",
    "create-admin": "node scripts/create-admin.js",
    "create-test-users": "node scripts/create-test-users.js",
    "seed-tenants": "node scripts/seed-tenants-test.js",
    "stress": "artillery run stress-tests/artillery-stress.yml",
    "stress:quick": "artillery run stress-tests/artillery-quick.yml",
    "stress:report": "node -e \"require('fs').mkdirSync('stress-tests/reports',{recursive:true})\" && artillery run stress-tests/artillery-stress.yml --output stress-tests/reports/report.json && node stress-tests/generate-report-html.js stress-tests/reports/report.json",
    "stress:load": "node stress-tests/run-load.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report tests/e2e/reports",
    "electron:dev": "electron electron/main.js",
    "electron:build": "electron-builder --win nsis"
  },
  "build": {
    "appId": "com.gastroflow.desktop",
    "productName": "GastroFlow",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "files": [
      "**/*",
      "!dist-electron{,/**/*}",
      "!.local-desktop{,/**/*}",
      "!.git{,/**/*}",
      "!.github{,/**/*}",
      "!.husky{,/**/*}",
      "!.claude{,/**/*}",
      "!.antigravitycli{,/**/*}",
      "!coverage{,/**/*}",
      "!test-results{,/**/*}",
      "!tests{,/**/*}",
      "!stress-tests{,/**/*}",
      "!docs{,/**/*}",
      "!logs{,/**/*}",
      "!storage{,/**/*}",
      "!.env",
      "!.env.test",
      "!.env.example",
      "!*.md",
      "!eslint.config.js",
      "!jest.config.js",
      "!playwright.config.js",
      "!.prettierrc",
      "!.prettierignore",
      "!.dockerignore",
      "!docker-compose.yml",
      "!Dockerfile",
      "!requerimientos.txt",
      "!skills-lock.json",
      "!node_modules/{@playwright,@eslint,@types,artillery,autocannon,electron,electron-builder,eslint,globals,husky,jest,lint-staged,nodemon,prettier,supertest}{,/**/*}"
    ],
    "extraResources": [
      {
        "from": "resources/mysql-portable",
        "to": "mysql-portable",
        "filter": ["**/*"]
      }
    ]
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@sentry/node": "^10.57.0",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.2",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.6.1",
    "ejs": "^3.1.9",
    "exceljs": "^3.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.14.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "25.3.0",
    "artillery": "^1.7.9",
    "autocannon": "^2.0.1",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^17.0.7",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.4",
    "supertest": "^6.3.4"
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "@opentelemetry/api": "1.9.0"
  }
}
