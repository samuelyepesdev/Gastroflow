  <!-- Dynamic Hover style execution helper -->
  <script>
    document.querySelectorAll('[style-hover]').forEach(el => {
      const originalStyle = el.getAttribute('style') || '';
      const hoverStyle = el.getAttribute('style-hover') || '';
      
      const parseStyle = (cssText) => {
        const rules = cssText.split(';').filter(rule => rule.trim());
        const styleObj = {};
        rules.forEach(rule => {
          const colonIdx = rule.indexOf(':');
          if (colonIdx !== -1) {
            const key = rule.slice(0, colonIdx).trim();
            const val = rule.slice(colonIdx + 1).trim();
            styleObj[key] = val;
          }
        });
        return styleObj;
      };

      const originalObj = parseStyle(originalStyle);
      const hoverObj = parseStyle(hoverStyle);

      el.addEventListener('mouseenter', () => {
        for (const [key, value] of Object.entries(hoverObj)) {
          el.style[key] = value;
        }
      });

      el.addEventListener('mouseleave', () => {
        for (const key of Object.keys(hoverObj)) {
          el.style[key] = originalObj[key] || '';
        }
        el.style.cssText = originalStyle;
      });
    });
  </script>
