<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>GastroFlow | Gestión Inteligente para Restaurantes</title>
  <meta name="description" content="GastroFlow conecta tus ventas, tu inventario y tu cocina en tiempo real. Fichas técnicas automatizadas, KDS y control total de tu margen.">
  
  <!-- Fonts & Icons -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  
  <style>
    :root {
      --color-primary: <%= settings.color_primary || '#3fc46d' %>;
      --color-primary-hover: <%= settings.color_primary_hover || '#2e7d46' %>;
      --color-background: <%= settings.color_background || '#080b09' %>;
      --color-text: <%= settings.color_text || '#e9efea' %>;
      --color-accent: <%= settings.color_accent || '#c2604f' %>;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { margin: 0; background: var(--color-background); color: var(--color-text); }
    ::-webkit-scrollbar { width: 10px; height: 10px; }
    ::-webkit-scrollbar-track { background: var(--color-background); }
    ::-webkit-scrollbar-thumb { background: color-mix(in srgb, var(--color-primary) 30%, transparent); border-radius: 8px; border: 2px solid transparent; background-clip: content-box; }
    a { text-decoration: none; }
    @keyframes reveal { from { opacity: 0; transform: translateY(26px); } to { opacity: 1; transform: none; } }
    @keyframes rise { from { opacity: 0; transform: translateY(18px); } to { opacity: 1; transform: none; } }
    @keyframes floaty { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-14px); } }
    @keyframes pulseGlow { 0%, 100% { opacity: .55; } 50% { opacity: .9; } }
    [data-reveal] { animation: reveal both linear; animation-timeline: view(); animation-range: entry 0% cover 24%; }
  </style>
</head>
<body>
  <div style="min-height:100vh;background:radial-gradient(1200px 700px at 80% -5%,color-mix(in srgb, var(--color-primary) 10%, transparent),transparent 60%),radial-gradient(900px 600px at 0% 30%,color-mix(in srgb, var(--color-primary-hover) 8%, transparent),transparent 55%),var(--color-background);color:var(--color-text);font-family:'Plus Jakarta Sans',system-ui,-apple-system,sans-serif;overflow-x:hidden;position:relative;line-height:1.6;">

    <!-- ambient glows -->
    <div style="position:absolute;top:-160px;right:-120px;width:520px;height:520px;background:radial-gradient(circle,color-mix(in srgb, var(--color-primary) 16%, transparent),transparent 65%);filter:blur(40px);border-radius:50%;pointer-events:none;animation:pulseGlow 9s ease-in-out infinite;"></div>
    <div style="position:absolute;top:620px;left:-180px;width:480px;height:480px;background:radial-gradient(circle,color-mix(in srgb, var(--color-primary-hover) 12%, transparent),transparent 65%);filter:blur(40px);border-radius:50%;pointer-events:none;"></div>

    <!-- NAV -->
    <header style="position:sticky;top:0;z-index:100;backdrop-filter:blur(14px);background:rgba(8,11,9,.72);border-bottom:1px solid rgba(255,255,255,.06);">
      <nav style="max-width:1180px;margin:0 auto;padding:14px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
        <a href="#top" style="display:flex;align-items:center;gap:10px;color:#fff;font-weight:800;font-size:19px;letter-spacing:-.02em;">
          <span style="width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg,var(--color-primary-hover),var(--color-primary));display:flex;align-items:center;justify-content:center;font-size:17px;box-shadow:0 6px 16px -4px color-mix(in srgb, var(--color-primary) 60%, transparent);"><i class="bi bi-fire"></i></span>
          GastroFlow
        </a>
        <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;justify-content:flex-end;">
          <a id="lnk-nav-funciones" href="#funciones" style="color:#9fb0a4;font-weight:600;font-size:14px;padding:8px 12px;border-radius:9px;transition:color .2s,background .2s;" style-hover="color:#fff;background:rgba(255,255,255,.05);">Funciones</a>
          <a id="lnk-nav-resultados" href="#resultados" style="color:#9fb0a4;font-weight:600;font-size:14px;padding:8px 12px;border-radius:9px;transition:color .2s,background .2s;" style-hover="color:#fff;background:rgba(255,255,255,.05);">Resultados</a>
          <a id="lnk-nav-precios" href="#precios" style="color:#9fb0a4;font-weight:600;font-size:14px;padding:8px 12px;border-radius:9px;transition:color .2s,background .2s;" style-hover="color:#fff;background:rgba(255,255,255,.05);">Planes</a>
          <a id="lnk-nav-login" href="/auth/login" style="color:#cdd8d0;font-weight:600;font-size:14px;padding:9px 14px;border-radius:10px;border:1px solid rgba(255,255,255,.12);transition:all .2s;white-space:nowrap;" style-hover="background:rgba(255,255,255,.06);color:#fff;">Iniciar sesión</a>
          <a id="lnk-nav-demo" href="https://wa.me/<%= settings.whatsapp_number %>?text=<%= encodeURIComponent(settings.whatsapp_message) %>" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:7px;background:linear-gradient(135deg,var(--color-primary-hover),var(--color-primary));color:#062012;font-weight:700;font-size:14px;padding:9px 16px;border-radius:10px;box-shadow:0 8px 20px -8px color-mix(in srgb, var(--color-primary) 70%, transparent);transition:transform .2s,box-shadow .2s;" style-hover="transform:translateY(-2px);box-shadow:0 12px 26px -8px color-mix(in srgb, var(--color-primary) 85%, transparent);"><i class="bi bi-whatsapp"></i>Agendar demo</a>
        </div>
      </nav>
    </header>

    <main id="top" style="position:relative;z-index:1;">

      <!-- HERO: split -->
      <section style="max-width:1180px;margin:0 auto;padding:clamp(48px,8vw,92px) 24px 30px;display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,330px),1fr));gap:clamp(32px,5vw,60px);align-items:center;">
        <div style="">
          <span style="display:inline-flex;align-items:center;gap:8px;background:color-mix(in srgb, var(--color-primary) 10%, transparent);color:var(--color-primary);border:1px solid color-mix(in srgb, var(--color-primary) 28%, transparent);padding:7px 15px;border-radius:30px;font-size:13px;font-weight:700;"><span style="width:7px;height:7px;border-radius:50%;background:var(--color-primary);box-shadow:0 0 8px var(--color-primary);"></span>El sistema operativo de tu cocina</span>
          <% 
            let heroTitleHtml = settings.hero_title || 'Deja de adivinar. Empieza a controlar tu margen.';
            if (settings.hero_highlight && heroTitleHtml.includes(settings.hero_highlight)) {
              const replacement = `<span style="background:linear-gradient(120deg,var(--color-primary),color-mix(in srgb, var(--color-primary) 60%, #fff));-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;">${settings.hero_highlight}</span>`;
              heroTitleHtml = heroTitleHtml.replace(settings.hero_highlight, replacement);
            }
          %>
          <h1 style="margin:22px 0 0;font-size:clamp(2.2rem,5.4vw,3.9rem);line-height:1.05;font-weight:800;letter-spacing:-.03em;color:#f4f8f5;"><%- heroTitleHtml %></h1>
          <p style="margin:22px 0 0;max-width:52ch;font-size:clamp(1.02rem,2vw,1.18rem);color:#9fb0a4;"><%= settings.hero_subtitle %></p>
          <div style="display:flex;flex-wrap:wrap;gap:13px;margin-top:30px;">
            <a id="btn-hero-demo" href="https://wa.me/<%= settings.whatsapp_number %>?text=<%= encodeURIComponent(settings.whatsapp_message) %>" target="_blank" rel="noopener noreferrer" style="display:inline-flex;align-items:center;gap:9px;background:linear-gradient(135deg,var(--color-primary-hover),var(--color-primary));color:#052010;font-weight:700;font-size:16px;padding:15px 26px;border-radius:13px;box-shadow:0 14px 34px -12px color-mix(in srgb, var(--color-primary) 75%, transparent);transition:transform .25s,box-shadow .25s;" style-hover="transform:translateY(-3px);box-shadow:0 20px 42px -12px color-mix(in srgb, var(--color-primary) 90%, transparent);"><i class="bi bi-whatsapp" style="font-size:18px;"></i>Agendar demo gratis</a>
            <a id="btn-hero-funciones" href="#funciones" style="display:inline-flex;align-items:center;gap:9px;color:#e9efea;font-weight:700;font-size:16px;padding:15px 24px;border-radius:13px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.025);transition:all .25s;" style-hover="background:rgba(255,255,255,.07);transform:translateY(-3px);">Ver funciones</a>
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:24px;margin-top:34px;padding-top:26px;border-top:1px solid rgba(255,255,255,.07);">
            <div><div style="font-size:1.7rem;font-weight:800;color:var(--color-primary);letter-spacing:-.02em;">+500</div><div style="font-size:13px;color:#8a978d;font-weight:600;">restaurantes activos</div></div>
            <div><div style="font-size:1.7rem;font-weight:800;color:var(--color-primary);letter-spacing:-.02em;">4.9/5</div><div style="font-size:13px;color:#8a978d;font-weight:600;">satisfacción</div></div>
            <div><div style="font-size:1.7rem;font-weight:800;color:var(--color-primary);letter-spacing:-.02em;">30 días</div><div style="font-size:13px;color:#8a978d;font-weight:600;">para ver resultados</div></div>
          </div>
        </div>
        <div style="animation-delay:.12s;animation-fill-mode:both;">
          <div style="border-radius:18px;border:1px solid rgba(255,255,255,.1);background:rgba(14,18,16,.7);box-shadow:0 40px 90px -30px rgba(0,0,0,.85),0 0 60px -20px color-mix(in srgb, var(--color-primary) 25%, transparent);overflow:hidden;">
            <div style="display:flex;align-items:center;gap:7px;padding:12px 15px;border-bottom:1px solid rgba(255,255,255,.07);background:rgba(255,255,255,.02);">
              <span style="width:10px;height:10px;border-radius:50%;background:#ff5f57;"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#febc2e;"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#28c840;"></span>
            </div>
            <img src="/assets/dashboard-preview.png" alt="Panel de control de GastroFlow" style="display:block;width:100%;height:auto;">
          </div>
        </div>
      </section>

      <!-- PROBLEMAS -->
      <section style="max-width:1180px;margin:0 auto;padding:clamp(60px,9vw,110px) 24px 0;">
        <div data-reveal style="text-align:center;max-width:48ch;margin:0 auto;">
          <span style="font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--color-accent);">El problema</span>
          <h2 style="margin:12px 0 0;font-size:clamp(1.7rem,4vw,2.6rem);font-weight:800;letter-spacing:-.025em;color:#f4f8f5;line-height:1.12;"><%= settings.problems_title %></h2>
          <p style="margin:16px auto 0;font-size:1.05rem;color:#9fb0a4;"><%= settings.problems_subtitle %></p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,250px),1fr));gap:18px;margin-top:48px;">
          <div data-reveal style="padding:26px;border-radius:18px;background:color-mix(in srgb, var(--color-accent) 5%, transparent);border:1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);transition:transform .25s,border-color .25s;" style-hover="transform:translateY(-5px);border-color:color-mix(in srgb, var(--color-accent) 40%, transparent);">
            <span style="width:46px;height:46px;border-radius:12px;background:color-mix(in srgb, var(--color-accent) 14%, transparent);color:color-mix(in srgb, var(--color-accent) 85%, #fff);display:flex;align-items:center;justify-content:center;font-size:21px;"><i class="bi bi-graph-down-arrow"></i></span>
            <h3 style="margin:18px 0 8px;font-size:1.18rem;font-weight:700;color:color-mix(in srgb, var(--color-accent) 90%, #fff);"><%= settings.problem1_title %></h3>
            <p style="margin:0;font-size:.97rem;color:#9fb0a4;"><%= settings.problem1_desc %></p>
          </div>
          <div data-reveal style="padding:26px;border-radius:18px;background:color-mix(in srgb, var(--color-accent) 5%, transparent);border:1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);transition:transform .25s,border-color .25s;" style-hover="transform:translateY(-5px);border-color:color-mix(in srgb, var(--color-accent) 40%, transparent);">
            <span style="width:46px;height:46px;border-radius:12px;background:color-mix(in srgb, var(--color-accent) 14%, transparent);color:color-mix(in srgb, var(--color-accent) 85%, #fff);display:flex;align-items:center;justify-content:center;font-size:21px;"><i class="bi bi-calculator"></i></span>
            <h3 style="margin:18px 0 8px;font-size:1.18rem;font-weight:700;color:color-mix(in srgb, var(--color-accent) 90%, #fff);"><%= settings.problem2_title %></h3>
            <p style="margin:0;font-size:.97rem;color:#9fb0a4;"><%= settings.problem2_desc %></p>
          </div>
          <div data-reveal style="padding:26px;border-radius:18px;background:color-mix(in srgb, var(--color-accent) 5%, transparent);border:1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);transition:transform .25s,border-color .25s;" style-hover="transform:translateY(-5px);border-color:color-mix(in srgb, var(--color-accent) 40%, transparent);">
            <span style="width:46px;height:46px;border-radius:12px;background:color-mix(in srgb, var(--color-accent) 14%, transparent);color:color-mix(in srgb, var(--color-accent) 85%, #fff);display:flex;align-items:center;justify-content:center;font-size:21px;"><i class="bi bi-fire"></i></span>
            <h3 style="margin:18px 0 8px;font-size:1.18rem;font-weight:700;color:color-mix(in srgb, var(--color-accent) 90%, #fff);"><%= settings.problem3_title %></h3>
            <p style="margin:0;font-size:.97rem;color:#9fb0a4;"><%= settings.problem3_desc %></p>
          </div>
          <div data-reveal style="padding:26px;border-radius:18px;background:color-mix(in srgb, var(--color-accent) 5%, transparent);border:1px solid color-mix(in srgb, var(--color-accent) 18%, transparent);transition:transform .25s,border-color .25s;" style-hover="transform:translateY(-5px);border-color:color-mix(in srgb, var(--color-accent) 40%, transparent);">
            <span style="width:46px;height:46px;border-radius:12px;background:color-mix(in srgb, var(--color-accent) 14%, transparent);color:color-mix(in srgb, var(--color-accent) 85%, #fff);display:flex;align-items:center;justify-content:center;font-size:21px;"><i class="bi bi-cash-stack"></i></span>
            <h3 style="margin:18px 0 8px;font-size:1.18rem;font-weight:700;color:color-mix(in srgb, var(--color-accent) 90%, #fff);"><%= settings.problem4_title %></h3>
            <p style="margin:0;font-size:.97rem;color:#9fb0a4;"><%= settings.problem4_desc %></p>
          </div>
        </div>
      </section>

      <!-- FUNCIONES -->
      <section id="funciones" style="max-width:1180px;margin:0 auto;padding:clamp(64px,10vw,120px) 24px 0;scroll-margin-top:80px;">
        <div data-reveal style="text-align:center;max-width:50ch;margin:0 auto;">
          <span style="font-size:13px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:color-mix(in srgb, var(--color-primary) 85%, #fff);">La solución</span>
          <h2 style="margin:12px 0 0;font-size:clamp(1.7rem,4vw,2.6rem);font-weight:800;letter-spacing:-.025em;color:#f4f8f5;line-height:1.12;"><%= settings.features_title %></h2>
          <p style="margin:16px auto 0;font-size:1.05rem;color:#9fb0a4;"><%= settings.features_subtitle %></p>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,290px),1fr));gap:18px;margin-top:48px;">
          <div data-reveal style="padding:30px;border-radius:18px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.08);transition:transform .3s,border-color .3s,background .3s;" style-hover="transform:translateY(-7px);border-color:color-mix(in srgb, var(--color-primary) 40%, transparent);background:color-mix(in srgb, var(--color-primary) 4%, transparent);">
            <span style="width:52px;height:52px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 12%, transparent);color:var(--color-primary);display:flex;align-items:center;justify-content:center;font-size:24px;border:1px solid color-mix(in srgb, var(--color-primary) 22%, transparent);"><i class="bi bi-clipboard-data"></i></span>
            <h3 style="margin:20px 0 9px;font-size:1.22rem;font-weight:700;color:#f4f8f5;"><%= settings.feature1_title %></h3>
            <p style="margin:0;font-size:.98rem;color:#9fb0a4;"><%= settings.feature1_desc %></p>
          </div>
          <div data-reveal style="padding:30px;border-radius:18px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.08);transition:transform .3s,border-color .3s,background .3s;" style-hover="transform:translateY(-7px);border-color:color-mix(in srgb, var(--color-primary) 40%, transparent);background:color-mix(in srgb, var(--color-primary) 4%, transparent);">
            <span style="width:52px;height:52px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 12%, transparent);color:var(--color-primary);display:flex;align-items:center;justify-content:center;font-size:24px;border:1px solid color-mix(in srgb, var(--color-primary) 22%, transparent);"><i class="bi bi-display"></i></span>
            <h3 style="margin:20px 0 9px;font-size:1.22rem;font-weight:700;color:#f4f8f5;"><%= settings.feature2_title %></h3>
            <p style="margin:0;font-size:.98rem;color:#9fb0a4;"><%= settings.feature2_desc %></p>
          </div>
          <div data-reveal style="padding:30px;border-radius:18px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.08);transition:transform .3s,border-color .3s,background .3s;" style-hover="transform:translateY(-7px);border-color:color-mix(in srgb, var(--color-primary) 40%, transparent);background:color-mix(in srgb, var(--color-primary) 4%, transparent);">
            <span style="width:52px;height:52px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 12%, transparent);color:var(--color-primary);display:flex;align-items:center;justify-content:center;font-size:24px;border:1px solid color-mix(in srgb, var(--color-primary) 22%, transparent);"><i class="bi bi-box-seam"></i></span>
            <h3 style="margin:20px 0 9px;font-size:1.22rem;font-weight:700;color:#f4f8f5;"><%= settings.feature3_title %></h3>
            <p style="margin:0;font-size:.98rem;color:#9fb0a4;"><%= settings.feature3_desc %></p>
          </div>
          <div data-reveal style="padding:30px;border-radius:18px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.08);transition:transform .3s,border-color .3s,background .3s;" style-hover="transform:translateY(-7px);border-color:color-mix(in srgb, var(--color-primary) 40%, transparent);background:color-mix(in srgb, var(--color-primary) 4%, transparent);">
            <span style="width:52px;height:52px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 12%, transparent);color:var(--color-primary);display:flex;align-items:center;justify-content:center;font-size:24px;border:1px solid color-mix(in srgb, var(--color-primary) 22%, transparent);"><i class="bi bi-shield-lock"></i></span>
            <h3 style="margin:20px 0 9px;font-size:1.22rem;font-weight:700;color:#f4f8f5;"><%= settings.feature4_title %></h3>
            <p style="margin:0;font-size:.98rem;color:#9fb0a4;"><%= settings.feature4_desc %></p>
          </div>
          <div data-reveal style="padding:30px;border-radius:18px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.08);transition:transform .3s,border-color .3s,background .3s;" style-hover="transform:translateY(-7px);border-color:color-mix(in srgb, var(--color-primary) 40%, transparent);background:color-mix(in srgb, var(--color-primary) 4%, transparent);">
            <span style="width:52px;height:52px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 12%, transparent);color:var(--color-primary);display:flex;align-items:center;justify-content:center;font-size:24px;border:1px solid color-mix(in srgb, var(--color-primary) 22%, transparent);"><i class="bi bi-grid-3x3-gap"></i></span>
            <h3 style="margin:20px 0 9px;font-size:1.22rem;font-weight:700;color:#f4f8f5;"><%= settings.feature5_title %></h3>
            <p style="margin:0;font-size:.98rem;color:#9fb0a4;"><%= settings.feature5_desc %></p>
          </div>
          <div data-reveal style="padding:30px;border-radius:18px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.08);transition:transform .3s,border-color .3s,background .3s;" style-hover="transform:translateY(-7px);border-color:color-mix(in srgb, var(--color-primary) 40%, transparent);background:color-mix(in srgb, var(--color-primary) 4%, transparent);">
            <span style="width:52px;height:52px;border-radius:14px;background:color-mix(in srgb, var(--color-primary) 12%, transparent);color:var(--color-primary);display:flex;align-items:center;justify-content:center;font-size:24px;border:1px solid color-mix(in srgb, var(--color-primary) 22%, transparent);"><i class="bi bi-patch-check"></i></span>
            <h3 style="margin:20px 0 9px;font-size:1.22rem;font-weight:700;color:#f4f8f5;"><%= settings.feature6_title %></h3>
            <p style="margin:0;font-size:.98rem;color:#9fb0a4;"><%= settings.feature6_desc %></p>
          </div>
        </div>
      </section>

      <!-- RESULTADOS / ROI -->
      <section id="resultados" style="max-width:1180px;margin:0 auto;padding:clamp(64px,10vw,120px) 24px 0;scroll-margin-top:80px;">
        <div data-reveal style="position:relative;overflow:hidden;border-radius:26px;border:1px solid color-mix(in srgb, var(--color-primary) 22%, transparent);background:linear-gradient(135deg,color-mix(in srgb, var(--color-primary-hover) 18%, transparent),color-mix(in srgb, var(--color-primary) 6%, transparent));padding:clamp(34px,5vw,58px);box-shadow:0 30px 80px -40px color-mix(in srgb, var(--color-primary) 40%, transparent);">
          <div style="position:absolute;top:-60px;right:-40px;width:280px;height:280px;background:radial-gradient(circle,color-mix(in srgb, var(--color-primary) 22%, transparent),transparent 65%);filter:blur(30px);pointer-events:none;"></div>
