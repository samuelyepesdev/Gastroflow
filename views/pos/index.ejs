<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Terminal POS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/core/index.css">
    <link rel="stylesheet" href="/css/modulos/pos.css">
</head>
<body class="pos-terminal-body">

<%- include('../partials/navbar', { user: typeof user !== 'undefined' ? user : null, tenant: typeof tenant !== 'undefined' ? tenant : null }) %>

<!-- Data island: productos y categorías del servidor -->
<script type="application/json" id="posInitData"><%- JSON.stringify({ productos: productos || [], categorias: categorias || [] }) %></script>

<div class="pos-wrapper">

    <!-- Barra de estadísticas -->
    <div class="pos-stats-bar">
        <div class="pos-stats-left">
            <i class="bi bi-lightning-charge-fill text-warning me-2"></i>
            <span class="fw-semibold">Terminal POS</span>
        </div>
        <div class="pos-stats-center">
            <span class="pos-stat-chip">
                <i class="bi bi-receipt me-1"></i>
                <span id="posStatsOrdenes">—</span> ventas hoy
            </span>
            <span class="pos-stat-divider">|</span>
            <span class="pos-stat-chip">
                <i class="bi bi-cash-stack me-1"></i>
                <span id="posStatsTotal">$0</span>
            </span>
        </div>
        <div class="pos-stats-right">
            <button class="btn btn-sm btn-outline-light" id="posBtnBorradores">
                <i class="bi bi-layers me-1"></i>
                Guardadas
                <span class="badge bg-warning text-dark ms-1" id="posBorradoresCount">0</span>
            </button>
        </div>
    </div>

    <!-- Área principal -->
    <div class="pos-main">

        <!-- Panel izquierdo: Catálogo -->
        <div class="pos-catalog">
            <div class="pos-search-wrap">
                <div class="input-group pos-search-input">
                    <span class="input-group-text bg-white border-0">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" id="posSearch" class="form-control border-0 shadow-none"
                        placeholder="Buscar producto o código..." autocomplete="off">
                    <button class="btn btn-link text-muted pe-2" id="posClearSearch" style="display:none;" title="Limpiar">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </div>
            </div>

            <div class="pos-cats-wrap">
                <div class="pos-cats-scroll" id="posCatsBar">
                    <button class="pos-cat-pill active" data-cat="all">
                        <i class="bi bi-grid-3x3 me-1"></i>Todos
                    </button>
                    <!-- Categorías inyectadas por JS -->
                </div>
            </div>

            <div class="pos-product-grid" id="posProductGrid">
                <!-- Productos inyectados por JS -->
                <div class="pos-catalog-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
        </div>

        <!-- Panel derecho: Carrito -->
        <div class="pos-cart-panel">

            <!-- Cliente -->
            <div class="pos-cart-customer">
                <div class="pos-customer-row">
                    <i class="bi bi-person-fill pos-customer-icon"></i>
                    <div class="pos-customer-input-wrap">
                        <input type="text" id="posClienteInput" class="form-control form-control-sm border-0 shadow-none"
                            placeholder="Consumidor final" autocomplete="off">
                        <input type="hidden" id="posClienteId">
                        <div id="posClienteSugerencias" class="pos-customer-dropdown"></div>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary pos-customer-new"
                        data-bs-toggle="modal" data-bs-target="#posNuevoClienteModal" title="Nuevo cliente">
                        <i class="bi bi-person-plus"></i>
                    </button>
                </div>
            </div>

            <!-- Items del carrito -->
            <div class="pos-cart-items" id="posCartItems">
                <div class="pos-cart-empty" id="posCartEmpty">
                    <i class="bi bi-cart-x"></i>
                    <p>Carrito vacío</p>
                    <small>Selecciona productos del catálogo</small>
                </div>
            </div>

            <!-- Footer del carrito -->
            <div class="pos-cart-footer">
                <div class="pos-totals">
                    <div class="pos-total-row pos-total-main">
                        <span class="fw-semibold">Total</span>
                        <span class="pos-total-amount" id="posCartTotal">$0</span>
                    </div>
                </div>

                <div class="pos-cart-actions">
                    <button class="btn btn-outline-secondary" id="posBtnAparcar" title="Guardar orden para después">
                        <i class="bi bi-bookmark me-1"></i>Guardar
                    </button>
                    <button class="btn btn-success pos-btn-cobrar" id="posBtnCobrar" disabled>
                        <i class="bi bi-lightning-charge me-1"></i>
                        Cobrar <span id="posCobrarTotal">$0</span>
                    </button>
                </div>

                <button class="btn btn-link btn-sm text-muted w-100 pos-btn-limpiar" id="posBtnLimpiar">
                    <i class="bi bi-x-circle me-1"></i>Limpiar orden
                </button>
            </div>
        </div>
    </div>
</div>

<!-- ======================== MODALES ======================== -->

<!-- Modal: Pago -->
<div class="modal fade" id="posPagoModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-success text-white py-3">
                <h5 class="modal-title fw-semibold">
                    <i class="bi bi-cash-stack me-2"></i>Cobrar venta
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">

                <!-- Resumen de items -->
                <div class="pos-pago-items mb-3" id="posPagoItems"></div>

                <!-- Métodos de pago -->
                <div class="mb-3">
                    <label class="form-label fw-semibold small text-muted text-uppercase">Forma de pago</label>
                    <div class="pos-pago-methods">
                        <button class="pos-method-btn active" data-method="efectivo">
                            <i class="bi bi-cash me-2"></i>Efectivo
                        </button>
                        <button class="pos-method-btn" data-method="transferencia">
                            <i class="bi bi-bank me-2"></i>Transferencia
                        </button>
                    </div>
                    <input type="hidden" id="posPagoMetodo" value="efectivo">
                </div>

                <!-- Calculadora de vuelto (solo efectivo) -->
                <div id="posEfectivoSection">
                    <div class="mb-3">
                        <label class="form-label fw-semibold small text-muted text-uppercase">Recibido</label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text fw-bold">$</span>
                            <input type="number" id="posEfectivoRecibido" class="form-control fw-bold"
                                placeholder="0" min="0" step="100">
                        </div>
                        <div class="pos-quick-amounts mt-2" id="posQuickAmounts"></div>
                    </div>
                    <div class="pos-vuelto-box" id="posVueltoBox">
                        <span class="pos-vuelto-label">Vuelto</span>
                        <span class="pos-vuelto-amount" id="posVueltoAmount">$0</span>
                    </div>
                </div>

                <!-- Total -->
                <div class="pos-pago-total-box">
                    <span>Total a cobrar</span>
                    <span class="pos-pago-total-amount" id="posPagoTotal">$0</span>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success btn-lg px-4" id="posConfirmarPagoBtn">
                    <i class="bi bi-check-circle me-1"></i>Confirmar Pago
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Recibo -->
<div class="modal fade" id="posReceiptModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-fullscreen-md-down">
        <div class="modal-content d-flex flex-column" style="height:90vh;">
            <div class="modal-header py-2">
                <h5 class="modal-title"><i class="bi bi-receipt me-2"></i>Recibo de venta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0 flex-grow-1" style="overflow:hidden;">
                <iframe id="posReceiptFrame" style="width:100%;height:100%;border:none;"></iframe>
            </div>
            <div class="modal-footer py-2">
                <button type="button" class="btn btn-primary btn-sm"
                    onclick="document.getElementById('posReceiptFrame').contentWindow.print()">
                    <i class="bi bi-printer me-1"></i>Imprimir
                </button>
                <button type="button" class="btn btn-success btn-sm" id="posReceiptNuevaVenta" data-bs-dismiss="modal">
                    <i class="bi bi-plus-circle me-1"></i>Nueva venta
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Descuento por ítem -->
<div class="modal fade" id="posDescModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white py-2">
                <h6 class="modal-title mb-0"><i class="bi bi-percent me-2"></i>Descuento</h6>
                <button type="button" class="btn-close btn-close-white btn-sm" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <p class="fw-semibold small mb-1" id="posDescNombre"></p>
                <p class="text-muted small mb-3">Precio unitario: <span id="posDescPrecio"></span></p>

                <div class="d-flex flex-wrap gap-1 mb-3">
                    <button class="btn btn-outline-primary btn-sm pos-desc-quick" data-pct="5">5%</button>
                    <button class="btn btn-outline-primary btn-sm pos-desc-quick" data-pct="10">10%</button>
                    <button class="btn btn-outline-primary btn-sm pos-desc-quick" data-pct="15">15%</button>
                    <button class="btn btn-outline-primary btn-sm pos-desc-quick" data-pct="20">20%</button>
                    <button class="btn btn-outline-primary btn-sm pos-desc-quick" data-pct="50">50%</button>
                </div>

                <div class="input-group input-group-sm mb-2">
                    <input type="number" id="posDescPct" class="form-control" placeholder="Otro %" min="0" max="100">
                    <button class="btn btn-primary" type="button" id="posDescAplicar">Aplicar</button>
                </div>
            </div>
            <div class="modal-footer py-2 border-0">
                <button type="button" class="btn btn-sm btn-outline-danger" id="posDescQuitar">
                    <i class="bi bi-x me-1"></i>Quitar descuento
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Órdenes guardadas -->
<div class="modal fade" id="posBorradoresModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-layers me-2"></i>Órdenes guardadas</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Cliente</th>
                                <th>Productos</th>
                                <th>Total</th>
                                <th>Guardada</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="posBorradoresTbody">
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    <i class="bi bi-inbox me-2"></i>No hay órdenes guardadas
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Nuevo cliente -->
<div class="modal fade" id="posNuevoClienteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-person-plus-fill me-2"></i>Nuevo cliente</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="posFormNuevoCliente">
                    <div class="mb-3">
                        <label class="form-label fw-medium">Nombre <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="posNuevoClienteNombre" required>
                    </div>
                    <div class="row g-2">
                        <div class="col-6">
                            <label class="form-label fw-medium">Teléfono</label>
                            <input type="text" class="form-control" id="posNuevoClienteTel">
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-medium">Dirección</label>
                            <input type="text" class="form-control" id="posNuevoClienteDir">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="posGuardarClienteBtn">
                    <i class="bi bi-save me-1"></i>Guardar cliente
                </button>
            </div>
        </div>
    </div>
</div>

<%- include('../partials/_version') %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="/js/modulos/pos/pos_api.js"></script>
<script src="/js/modulos/pos/pos_core.js"></script>
<script src="/js/modulos/pos/pos_ui.js"></script>
<script src="/js/modulos/pos/pos_pago.js"></script>
</body>
</html>
