<!-- Vista Parcial: _grid.ejs -->
<div class="row grid-mesas">
    <% mesas.forEach(m => { %>
        <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4 px-2">
            <div class="card mesa-card mesa-real-card <%= m.estado %> <%= m.tipo === 'virtual' ? 'virtual' : '' %>"
                data-mesa-id="<%= m.id %>" data-mesa-estado="<%= m.estado %>" data-mesa-titulo="Mesa <%= m.numero %>">
                
                <% if (m.tipo === 'virtual') { %>
                    <!-- Tarjeta de Mesa Virtual (WhatsApp / Domicilios) -->
                    <div class="card-body p-3 text-center d-flex flex-column h-100 justify-content-between">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="mesa-num d-flex align-items-center">
                                <i class="bi bi-whatsapp text-success fs-5 me-2"></i>
                                <span class="fw-bold text-dark fs-5">Mesa <%= m.numero %></span>
                            </div>
                            <span class="mesa-estado-pill pill-<%= m.estado %>">
                                <i class="bi bi-circle-fill" style="font-size:.4rem; margin-right:4px;"></i><%= m.estado.toUpperCase() %>
                            </span>
                        </div>
                        
                        <div class="mesa-desc mb-3 py-2 bg-light rounded-3 text-dark fw-bold border-start border-success border-3">
                            <i class="bi bi-person me-1 text-success"></i><%= m.descripcion || 'Pedido WhatsApp' %>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <button class="btn btn-success btn-cta btnAbrirPedido py-2 rounded-3 fw-bold">
                                <i class="bi bi-plus-circle me-1"></i>Abrir pedido
                            </button>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-secondary btn-sec flex-fill btnVerPedido rounded-3 py-1_5" title="Ver pedido">
                                    <i class="bi bi-list-ul me-1"></i>Ver
                                </button>
                                <% if (m.estado !== 'libre') { %>
                                    <button class="btn btn-outline-secondary btn-sec flex-fill btnLiberarMesa rounded-3 py-1_5" title="Liberar mesa">
                                        <i class="bi bi-unlock me-1"></i>Liberar
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } else { %>
                    <!-- Tarjeta de Mesa Física Real (Estilo Loggro Restobar con Relieve 3D) -->
                    <div class="card-body p-3 d-flex flex-column align-items-center justify-content-center text-center">
                        
                        <!-- Representación Gráfica de la Mesa Física Vistas desde Arriba (Cenital) -->
                        <div class="mesa-real-layout-wrapper my-4 position-relative">
                            
                            <!-- Sillas Físicas alrededor de la mesa -->
                            <div class="mesa-real-sillas">
                                <span class="silla-real-item silla-top"></span>
                                <span class="silla-real-item silla-right"></span>
                                <span class="silla-real-item silla-bottom"></span>
                                <span class="silla-real-item silla-left"></span>
                            </div>

                            <!-- Cuerpo de la Mesa (Madera lacada o Cristal premium) -->
                            <div class="mesa-real-objeto-cuerpo d-flex flex-column align-items-center justify-content-center">
                                <div class="mesa-real-objeto-brillo"></div>
                                <span class="mesa-real-objeto-num">Mesa <%= m.numero %></span>
                                
                                <% if (m.estado === 'ocupada') { %>
                                    <span class="mesa-real-objeto-badge badge bg-danger border border-light animate-pulse"><i class="bi bi-egg-fried me-1"></i>ACTIVA</span>
                                <% } else if (m.estado === 'reservada') { %>
                                    <span class="mesa-real-objeto-badge badge bg-warning text-dark border border-light">RES</span>
                                <% } else { %>
                                    <span class="mesa-real-objeto-badge text-white-50 fs-9">Libre</span>
                                <% } %>
                            </div>
                        </div>

                        

                        <!-- Botones de Acción de Alta Gama (Integrados) -->
                        <div class="w-100">
                            <div class="d-grid gap-2">
                                <% if (m.estado === 'libre') { %>
                                    <button class="btn btn-success btn-cta btn-premium-action btnAbrirPedido w-100">
                                        <i class="bi bi-plus-circle me-1"></i>Abrir comanda
                                    </button>
                                <% } else { %>
                                    <button class="btn btn-warning btn-cta btn-premium-action text-dark btnAbrirPedido w-100">
                                        <i class="bi bi-pencil-square me-1"></i>Gestionar mesa
                                    </button>
                                <% } %>
                                
                                <div class="d-flex gap-2">
                                    <button class="btn btn-outline-secondary btn-sec btn-premium-secondary flex-fill btnVerPedido" title="Ver pedido de esta mesa">
                                        <i class="bi bi-list-ul"></i>
                                    </button>
                                    
                                    <% if (m.estado !== 'libre') { %>
                                        <button class="btn btn-outline-danger btn-sec btn-premium-secondary flex-fill btnLiberarMesa" title="Liberar mesa inmediatamente">
                                            <i class="bi bi-unlock"></i>
                                        </button>
                                    <% } %>

                                    <% if (user && user.permisos && user.permisos.includes('mesas.editar')) { %>
                                        <button class="btn btn-outline-secondary btn-sec btn-premium-secondary btnEditarMesa"
                                            data-mesa-numero="<%= m.numero %>"
                                            data-mesa-descripcion="<%= (m.descripcion || '') %>"
                                            title="Editar número/nombre de mesa">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    <% } %>

                                    <% if (user && user.permisos && user.permisos.includes('mesas.eliminar')) { %>
                                        <button class="btn btn-outline-danger btn-sec btn-premium-secondary btnEliminarMesa" title="Eliminar mesa permanentemente">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% } %>

            </div>
        </div>
    <% }) %>
</div>