    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Quill Library -->
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.2/dist/quill.js"></script>
    
    <script>
        // Initialize Quill editors
        const quillPrivacy = new Quill('#editor_privacy', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link', 'clean']
                ]
            }
        });

        const quillTerms = new Quill('#editor_terms', {
            theme: 'snow',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'strike'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['link', 'clean']
                ]
            }
        });

        // Set hidden fields values on submit
        const form = document.querySelector('form');
        form.addEventListener('submit', function(e) {
            // Get Quill's internal HTML representation
            const privacyHtml = quillPrivacy.root.innerHTML;
            const termsHtml = quillTerms.root.innerHTML;

            document.getElementById('privacy_policy_input').value = privacyHtml;
            document.getElementById('terms_conditions_input').value = termsHtml;
        });

        // Live color preview logic
        const mockup = document.getElementById('live-preview-mockup');
        const colorPrimary = document.getElementById('color_primary');
        const colorPrimaryHover = document.getElementById('color_primary_hover');
        const colorAccent = document.getElementById('color_accent');
        const colorBackground = document.getElementById('color_background');
        const colorText = document.getElementById('color_text');

        function updatePreview() {
            mockup.style.setProperty('--preview-bg', colorBackground.value);
            mockup.style.setProperty('--preview-text', colorText.value);
            mockup.style.setProperty('--preview-primary', colorPrimary.value);
            mockup.style.setProperty('--preview-primary-hover', colorPrimaryHover.value);
            mockup.style.setProperty('--preview-accent', colorAccent.value);

            // Update text representations
            document.getElementById('val_color_primary').textContent = colorPrimary.value.toUpperCase();
            document.getElementById('val_color_primary_hover').textContent = colorPrimaryHover.value.toUpperCase();
            document.getElementById('val_color_accent').textContent = colorAccent.value.toUpperCase();
            document.getElementById('val_color_background').textContent = colorBackground.value.toUpperCase();
            document.getElementById('val_color_text').textContent = colorText.value.toUpperCase();
        }

        // Add listeners to picker inputs
        [colorPrimary, colorPrimaryHover, colorAccent, colorBackground, colorText].forEach(input => {
            input.addEventListener('input', updatePreview);
        });

        // Initial preview update
        updatePreview();
    </script>
</body>

